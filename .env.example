# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///./vela.db

# Application Settings
APP_ENV=development
APP_BASE_URL=http://localhost:8000
SECRET_KEY=dev-secret-key-change-in-production

# GitHub (optional — only for GitHub module hub operations)
GITHUB_TOKEN=

# Module filter (glob patterns, comma-separated. Empty = load all)
# VELA_MODULES=migration-*,team-a-*

# Vela Directories
VELA_WORKFLOWS_DIR=~/.vela/workflows
VELA_AGENTS_DIR=~/.vela/agents

# Local modules directory
VELA_LOCAL_MODULES_DIR=~/.vela/modules

# Monitoring (Sentry)
SENTRY_DSN=

# Server Configuration
MCP_PORT=8000
HOST=0.0.0.0
